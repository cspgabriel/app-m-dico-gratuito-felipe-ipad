{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/billing/:path*", "destination": "/api/billing/:path*" },
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/((?!api/|.well-known/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
