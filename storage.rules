rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Default Deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isVerified() && request.auth.uid == uid; }
    function isImage()    { return request.resource.contentType.matches('image/.*'); }
    function isPdf()      { return request.resource.contentType == 'application/pdf'; }
    function maxSize(mb)  { return request.resource.size < mb * 1024 * 1024; }

    // Logo da clinica — leitura autenticada (aparece em PDFs/landing)
    // FIX: era read:true (publico) — alterado para isSignedIn()
    match /tenants/{uid}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isOwner(uid) && isImage() && maxSize(2);
    }

    // Avatares de usuarios
    match /users/{uid}/avatar/{fileName} {
      allow read:  if isSignedIn();
      allow write: if isOwner(uid) && isImage() && maxSize(2);
    }

    // Exames e documentos do paciente — somente medico dono
    match /pacientes/{uid}/{pacienteId}/{fileName} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid) && (isImage() || isPdf()) && maxSize(10);
      allow update: if isOwner(uid) && (isImage() || isPdf()) && maxSize(10);
      allow delete: if isOwner(uid);
    }

    // Uploads gerais por usuario
    match /uploads/{uid}/{allPaths=**} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid) && maxSize(10);
    }
  }
}
