rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ---------- Helpers ----------
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid)  { return isSignedIn() && request.auth.uid == uid; }
    function isImage()     { return request.resource.contentType.matches('image/.*'); }
    function isPdf()       { return request.resource.contentType == 'application/pdf'; }
    function maxSize(mb)   { return request.resource.size < mb * 1024 * 1024; }

    // ---------- Default Deny ----------
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ---------- Logo da clínica / branding ----------
    // Caminho usado pelo OnboardingPage:  tenants/{uid}/logo-...
    match /tenants/{uid}/{allPaths=**} {
      allow read: if true;                                       // logo público (aparece em PDFs/landing)
      allow write: if isOwner(uid) && isImage() && maxSize(2);   // só o dono pode subir, até 2MB, só imagem
    }

    // ---------- Avatares de usuários ----------
    match /users/{uid}/avatar/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) && isImage() && maxSize(2);
    }

    // ---------- Exames / Documentos do paciente ----------
    // Estrutura: pacientes/{uid_do_tenant}/{pacienteId}/{arquivo}
    match /pacientes/{uid}/{pacienteId}/{fileName} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid) && (isImage() || isPdf()) && maxSize(10);
      allow update: if isOwner(uid) && (isImage() || isPdf()) && maxSize(10);
      allow delete: if isOwner(uid);
    }

    // ---------- Anexos gerais por usuário ----------
    match /uploads/{uid}/{allPaths=**} {
      allow read:   if isOwner(uid);
      allow write:  if isOwner(uid) && maxSize(10);
    }
  }
}
