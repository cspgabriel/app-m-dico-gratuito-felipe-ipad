rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Paciente Validation
    function isValidPaciente(data) {
      return data.keys().hasAll(['nome', 'userId', 'createdAt', 'updatedAt']) &&
             data.nome is string && data.nome.size() <= 200 &&
             data.userId == request.auth.uid &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    // PACIENTES
    match /pacientes/{pacienteId} {
      allow create: if isSignedIn() && isValidPaciente(incoming()) && isValidId(pacienteId);
      allow get, list: if isSignedIn() && existing().userId == request.auth.uid;
      allow update: if isSignedIn() && 
                      existing().userId == request.auth.uid && 
                      isValidPaciente(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      // SUBCOLLECTIONS (Anamneses, Consultas, Prescricoes)
      match /anamneses/{id} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/pacientes/$(pacienteId)).data.userId == request.auth.uid;
      }
      match /consultas/{id} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/pacientes/$(pacienteId)).data.userId == request.auth.uid;
      }
      match /prescricoes/{id} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/pacientes/$(pacienteId)).data.userId == request.auth.uid;
      }
    }
  }
}
